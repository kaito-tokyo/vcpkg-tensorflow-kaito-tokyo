From 58671a8934dfbb13e738887d4e012d9aea04585b Mon Sep 17 00:00:00 2001
From: Kaito Udagawa <umireon@kaito.tokyo>
Date: Tue, 21 Apr 2026 04:01:31 +0900
Subject: [PATCH] Enable neon2sse for x86_64 cross building

Signed-off-by: Kaito Udagawa <umireon@kaito.tokyo>
---
 tensorflow/lite/CMakeLists.txt | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/tensorflow/lite/CMakeLists.txt b/tensorflow/lite/CMakeLists.txt
index 0924ca9dacd706..eac52cde23a327 100644
--- a/tensorflow/lite/CMakeLists.txt
+++ b/tensorflow/lite/CMakeLists.txt
@@ -149,7 +149,7 @@ find_package(farmhash REQUIRED)
 find_package(fft2d REQUIRED)
 find_package(FlatBuffers REQUIRED)
 find_package(gemmlowp REQUIRED)
-if (NOT CMAKE_SYSTEM_PROCESSOR OR CMAKE_SYSTEM_PROCESSOR MATCHES "x86")
+if (NOT CMAKE_SYSTEM_PROCESSOR OR CMAKE_SYSTEM_PROCESSOR MATCHES "x86" OR CMAKE_OSX_ARCHITECTURES MATCHES "x86_64")
   find_package(NEON_2_SSE REQUIRED)
   list(APPEND TFLITE_TARGET_DEPENDENCIES NEON_2_SSE::NEON_2_SSE)
 endif()
