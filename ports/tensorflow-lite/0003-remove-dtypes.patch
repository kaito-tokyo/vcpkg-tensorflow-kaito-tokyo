From f8ade3623d5001dd1f2e0bfb1a2cd1a00b312dcd Mon Sep 17 00:00:00 2001
From: Kaito Udagawa <umireon@kaito.tokyo>
Date: Tue, 21 Apr 2026 04:50:13 +0900
Subject: [PATCH] Remove ml_dtypes

Signed-off-by: Kaito Udagawa <umireon@kaito.tokyo>
---
 tensorflow/lite/CMakeLists.txt | 2 --
 1 file changed, 2 deletions(-)

diff --git a/tensorflow/lite/CMakeLists.txt b/tensorflow/lite/CMakeLists.txt
index eac52cde23a327..29a237ec566850 100644
--- a/tensorflow/lite/CMakeLists.txt
+++ b/tensorflow/lite/CMakeLists.txt
@@ -154,7 +154,6 @@ if (NOT CMAKE_SYSTEM_PROCESSOR OR CMAKE_SYSTEM_PROCESSOR MATCHES "x86" OR CMAKE_
   list(APPEND TFLITE_TARGET_DEPENDENCIES NEON_2_SSE::NEON_2_SSE)
 endif()
 find_package(cpuinfo REQUIRED)  #CPUINFO is used by XNNPACK and RUY library
-find_package(ml_dtypes REQUIRED)
 find_package(ruy REQUIRED)
 # Download necessary dependencies.
 # Download pthreadpool source package if it doesn't exist.
@@ -621,7 +620,6 @@ target_link_libraries(tensorflow-lite
     fft2d_fftsg2d
     flatbuffers::flatbuffers
     gemmlowp::gemmlowp
-    ml_dtypes
     ruy::ruy
     pthreadpool
     ${CMAKE_DL_LIBS}
